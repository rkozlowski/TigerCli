{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "src": "../..",
          "files": [
            "ItTiger.TigerCli/ItTiger.TigerCli.csproj",
            "ItTiger.Core/ItTiger.Core.csproj",
            "ItTiger.TigerCli.PngSink/ItTiger.TigerCli.PngSink.csproj"
          ]
        }
      ],
      "dest": "api",
      "shouldSkipMarkup": true
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "api/**.yml",
          "toc.yml",
          "index.md",
          "visual-reference.md"
        ]
      },
      {
        "src": "..",
        "files": [
          "reference/api-map.md"
        ]
      }
    ],
    "resource": [
      {
        "src": "..",
        "files": [
          "reference/cli-color.html",
          "examples/theme-dark.html",
          "examples/theme-light.html",
          "examples/theme-tiger-blue.html"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern",
      "templates/tigercli"
    ],
    "globalMetadata": {
      "_appName": "TigerCli",
      "_appTitle": "TigerCli API Reference",
      "_enableSearch": true
    }
  }
}
